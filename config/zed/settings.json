{
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "features": {
    "inline_completion_provider": "none"
  },
  "assistant": {
    "enabled": false
  },
  "vim_mode": false,
  "base_keymap": "VSCode",
  "theme": {
    "mode": "dark",
    "dark": "One Dark",
    "light": "One Light"
  },
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "tab_size": 4,
  "detect_indent": false,
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "soft_wrap": "none",
  "show_whitespaces": "boundary",
  "auto_save": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },
  "gutter": {
    "line_numbers": true
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": false
    }
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  "load_direnv": "shell_hook",
  "file_scan_exclusions": [
    "**/.git",
    "**/.direnv",
    "**/node_modules",
    "**/target",
    "**/__pycache__",
    "**/.venv",
    "**/venv"
  ],
  "auto_install_extensions": {
    "nix": true,
    "toml": true,
    "go": true
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path_lookup": true
      },
      "initialization_options": {
        "check": {
          "command": "clippy"
        },
        "cargo": {
          "features": "all"
        }
      }
    },
    "nixd": {
      "binary": {
        "path_lookup": true
      }
    }
  },
  "languages": {
    "Nix": {
      "language_servers": [
        "nixd",
        "!nil"
      ],
      "tab_size": 2,
      "format_on_save": {
        "external": {
          "command": "nixfmt",
          "arguments": [
            "-"
          ]
        }
      }
    },
    "Rust": {
      "tab_size": 4
    },
    "JSON": {
      "tab_size": 2
    },
    "JSONC": {
      "tab_size": 2
    },
    "YAML": {
      "tab_size": 2
    },
    "TOML": {
      "tab_size": 2
    },
    "C++": {
      "tab_size": 4
    },
    "Go": {
      "tab_size": 4
    }
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 13,
    "working_directory": "current_project_directory",
    "shell": {
      "program": "/run/current-system/sw/bin/fish"
    },
    "blinking": "off",
    "line_height": "comfortable",
    "copy_on_select": false,
    "dock": "bottom"
  }
}
